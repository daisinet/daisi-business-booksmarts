@using Daisi.SDK.Web.Services
@using Daisi.SDK.Models

<div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background: var(--bs-body-bg, #f8f9fa);">
    <div class="bs-card text-center" style="max-width: 480px;">
        <i class="fa-duotone fa-shield-xmark" style="font-size: 3rem; color: #dc3545;"></i>
        <h4 class="mt-3">Access Denied</h4>
        <p class="text-muted">
            You don't have access to BookSmarts for this account. Ask the account owner to
            invite you from the <strong>Settings &gt; Team</strong> page.
        </p>
        <button class="btn btn-outline-secondary" @onclick="SignOut">
            <i class="fa-duotone fa-arrow-right-from-bracket me-1"></i> Sign Out
        </button>
    </div>
</div>

@code {
    [Inject] AuthService Auth { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;

    private async Task SignOut()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/welcome", true);
    }
}

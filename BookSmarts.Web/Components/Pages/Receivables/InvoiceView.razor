@page "/invoices/{Id}"

<h1 class="bs-page-title">Invoice @(invoice?.InvoiceNumber ?? "")</h1>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" />
}
else if (invoice == null)
{
    <div class="bs-empty">
        <i class="fa-duotone fa-circle-exclamation"></i>
        <h4>Invoice not found</h4>
        <a href="invoices">Back to list</a>
    </div>
}
else
{
    <div class="bs-card" style="max-width: 900px;">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <span class="bs-badge bs-badge-@invoice.Status.ToString().ToLower() me-2">@invoice.Status</span>
                <span class="small text-muted">Terms: @FormatTerms(invoice.PaymentTerms)</span>
            </div>
            <div class="d-flex gap-2">
                @if (invoice.Status == InvoiceStatus.Draft)
                {
                    <a href="invoices/@invoice.id/edit" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-duotone fa-pen me-1"></i> Edit
                    </a>
                    <button class="btn btn-success btn-sm" @onclick="Send" disabled="@acting">
                        <i class="fa-duotone fa-paper-plane me-1"></i> Send
                    </button>
                }
                @if (invoice.Status is InvoiceStatus.Sent or InvoiceStatus.PartiallyPaid or InvoiceStatus.Overdue)
                {
                    <a href="payments/receive?invoiceId=@invoice.id" class="btn btn-primary btn-sm">
                        <i class="fa-duotone fa-hand-holding-dollar me-1"></i> Record Payment
                    </a>
                }
                @if (invoice.Status != InvoiceStatus.Voided && invoice.Status != InvoiceStatus.Paid)
                {
                    <button class="btn btn-warning btn-sm" @onclick="Void" disabled="@acting">
                        <i class="fa-duotone fa-ban me-1"></i> Void
                    </button>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label text-muted small">Customer</label>
                <div>@invoice.CustomerName</div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted small">Invoice Date</label>
                <div>@invoice.InvoiceDate.ToString("MMMM d, yyyy")</div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted small">Due Date</label>
                <div class="@(invoice.DueDate < DateTime.Today && invoice.BalanceDue > 0 ? "text-danger fw-bold" : "")">
                    @invoice.DueDate.ToString("MMMM d, yyyy")
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(invoice.Notes))
        {
            <div class="mb-3">
                <label class="form-label text-muted small">Notes</label>
                <div>@invoice.Notes</div>
            </div>
        }

        <table class="bs-table bs-table-striped mt-3">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Description</th>
                    <th>Account</th>
                    <th class="bs-amount">Qty</th>
                    <th class="bs-amount">Unit Price</th>
                    <th class="bs-amount">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in invoice.Lines)
                {
                    <tr>
                        <td>@line.LineNumber</td>
                        <td>@line.Description</td>
                        <td><code>@line.AccountNumber</code> @line.AccountName</td>
                        <td class="bs-amount">@line.Quantity</td>
                        <td class="bs-amount">@line.UnitPrice.ToString("N2")</td>
                        <td class="bs-amount">@line.Amount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold">
                    <td colspan="5" class="text-end">Total:</td>
                    <td class="bs-amount">@invoice.Total.ToString("N2")</td>
                </tr>
                @if (invoice.AmountPaid > 0)
                {
                    <tr>
                        <td colspan="5" class="text-end">Amount Paid:</td>
                        <td class="bs-amount text-success">(@invoice.AmountPaid.ToString("N2"))</td>
                    </tr>
                    <tr class="fw-bold">
                        <td colspan="5" class="text-end">Balance Due:</td>
                        <td class="bs-amount @(invoice.BalanceDue > 0 ? "text-danger" : "text-success")">@invoice.BalanceDue.ToString("N2")</td>
                    </tr>
                }
            </tfoot>
        </table>

        @if (!string.IsNullOrEmpty(invoice.JournalEntryId))
        {
            <div class="mt-3 small">
                <i class="fa-duotone fa-link me-1 text-muted"></i>
                Journal Entry: <a href="journal-entries/@invoice.JournalEntryId">@invoice.JournalEntryId</a>
            </div>
        }

        <div class="row mt-4 small text-muted">
            <div class="col-md-6">Created: @invoice.CreatedUtc.ToString("g")</div>
            @if (invoice.UpdatedUtc.HasValue)
            {
                <div class="col-md-6">Updated: @invoice.UpdatedUtc.Value.ToString("g")</div>
            }
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger mt-3">@error</div>
        }

        <div class="mt-3">
            <a href="invoices" class="btn btn-outline-secondary btn-sm">
                <i class="fa-duotone fa-arrow-left me-1"></i> Back to list
            </a>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    [CascadingParameter(Name = "CompanyId")] string? CompanyId { get; set; }
    [Inject] InvoiceService InvoiceSvc { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;

    private Invoice? invoice;
    private bool loading = true;
    private bool acting;
    private string? error;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(CompanyId) || string.IsNullOrEmpty(Id)) return;
        loading = true;
        try { invoice = await InvoiceSvc.GetInvoiceAsync(Id, CompanyId!); } catch { }
        loading = false;
    }

    private async Task Send()
    {
        error = null; acting = true;
        try { invoice = await InvoiceSvc.SendInvoiceAsync(Id, CompanyId!); }
        catch (Exception ex) { error = ex.Message; }
        acting = false;
    }

    private async Task Void()
    {
        error = null; acting = true;
        try { invoice = await InvoiceSvc.VoidInvoiceAsync(Id, CompanyId!); }
        catch (Exception ex) { error = ex.Message; }
        acting = false;
    }

    private static string FormatTerms(PaymentTerms t) => t switch
    {
        PaymentTerms.DueOnReceipt => "Due on Receipt",
        _ => t.ToString().Replace("Net", "Net ")
    };
}

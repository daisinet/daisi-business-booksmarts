@page "/journal-entries/new"

<h1 class="bs-page-title">New Journal Entry</h1>
<p class="bs-page-subtitle">Create a balanced double-entry journal entry</p>

@if (string.IsNullOrEmpty(CompanyId))
{
    <div class="bs-empty">
        <i class="fa-duotone fa-pen-to-square"></i>
        <h4>No company selected</h4>
    </div>
}
else
{
    @* ── Natural Language Journal Entry ── *@
    <div class="bs-card mb-3" style="max-width: 900px; border-left: 3px solid var(--bs-accent, #6366f1);">
        <div class="d-flex align-items-center mb-2">
            <i class="fa-duotone fa-wand-magic-sparkles me-1" style="color: var(--bs-accent, #6366f1);"></i>
            <strong class="small">Describe in Plain English</strong>
        </div>
        <div class="d-flex gap-2">
            <input type="text" class="form-control form-control-sm" @bind="nlDescription"
                   placeholder="e.g. Paid $500 rent for January from checking account" @onkeydown="HandleNlKeyDown" />
            <button class="btn btn-outline-primary btn-sm" @onclick="GenerateFromNL" disabled="@nlLoading" style="white-space: nowrap;">
                @if (nlLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="fa-duotone fa-wand-magic-sparkles me-1"></i> Generate
            </button>
        </div>
        @if (!string.IsNullOrEmpty(nlError))
        {
            <div class="small text-warning mt-1">@nlError</div>
        }
    </div>

    <div class="bs-card" style="max-width: 900px;">
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Date</label>
                <input type="date" class="form-control" @bind="entryDate" />
            </div>
            <div class="col-md-8">
                <label class="form-label">Description</label>
                <input type="text" class="form-control" @bind="description" placeholder="Description of the journal entry" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Memo</label>
            <textarea class="form-control" rows="2" @bind="memo" placeholder="Optional memo"></textarea>
        </div>

        <h6 class="mt-4 mb-2">Lines</h6>
        <table class="bs-table">
            <thead>
                <tr>
                    <th style="width: 40%;">Account</th>
                    <th>Description</th>
                    <th class="bs-amount" style="width: 130px;">Debit</th>
                    <th class="bs-amount" style="width: 130px;">Credit</th>
                    <th style="width: 40px;"></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < lines.Count; i++)
                {
                    var idx = i;
                    <tr>
                        <td>
                            <select class="form-select form-select-sm" @bind="lines[idx].AccountId" @bind:after="() => OnAccountSelected(idx)">
                                <option value="">— Select Account —</option>
                                @foreach (var acct in accounts)
                                {
                                    <option value="@acct.id">@acct.AccountNumber — @acct.Name</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input type="text" class="form-control form-control-sm" @bind="lines[idx].Description" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm text-end" @bind="lines[idx].Debit" step="0.01" min="0" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm text-end" @bind="lines[idx].Credit" step="0.01" min="0" />
                        </td>
                        <td>
                            @if (lines.Count > 2)
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(idx)">
                                    <i class="fa-duotone fa-times"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="2" class="text-end fw-bold">Totals:</td>
                    <td class="bs-amount fw-bold @(IsBalanced ? "" : "text-danger")">@TotalDebit.ToString("N2")</td>
                    <td class="bs-amount fw-bold @(IsBalanced ? "" : "text-danger")">@TotalCredit.ToString("N2")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>

        <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="AddLine">
            <i class="fa-duotone fa-plus me-1"></i> Add Line
        </button>

        @if (!IsBalanced && TotalDebit + TotalCredit > 0)
        {
            <div class="alert alert-warning mt-3">
                <i class="fa-duotone fa-triangle-exclamation me-1"></i>
                Entry is not balanced. Difference: @Math.Abs(TotalDebit - TotalCredit).ToString("N2")
            </div>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger mt-3">@error</div>
        }

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-primary" @onclick="SaveDraft" disabled="@saving">
                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Save as Draft
            </button>
            <button class="btn btn-success" @onclick="SaveAndPost" disabled="@saving">
                @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Save & Post
            </button>
            <a href="journal-entries" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
}

@code {
    [CascadingParameter(Name = "CompanyId")] string? CompanyId { get; set; }
    [Inject] AccountingService Accounting { get; set; } = default!;
    [Inject] ChartOfAccountsService CoaService { get; set; } = default!;
    [Inject] BookSmarts.Web.Services.BookSmartsInferenceService InferenceService { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;

    private List<ChartOfAccountEntry> accounts = new();
    private List<JournalLine> lines = new() { new(), new() };
    private DateTime entryDate = DateTime.Today;
    private string description = "";
    private string memo = "";
    private bool saving;
    private string? error;

    // Natural language entry
    private string nlDescription = "";
    private bool nlLoading;
    private string? nlError;

    private decimal TotalDebit => lines.Sum(l => l.Debit);
    private decimal TotalCredit => lines.Sum(l => l.Credit);
    private bool IsBalanced => TotalDebit == TotalCredit && TotalDebit > 0;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(CompanyId)) return;
        try
        {
            accounts = await CoaService.GetChartOfAccountsAsync(CompanyId!);
        }
        catch { }
    }

    private void AddLine() => lines.Add(new JournalLine());

    private void RemoveLine(int idx)
    {
        if (lines.Count > 2) lines.RemoveAt(idx);
    }

    private void OnAccountSelected(int idx)
    {
        var acct = accounts.FirstOrDefault(a => a.id == lines[idx].AccountId);
        if (acct != null)
        {
            lines[idx].AccountNumber = acct.AccountNumber;
            lines[idx].AccountName = acct.Name;
        }
    }

    private async Task SaveDraft()
    {
        var entry = await SaveEntry();
        if (entry != null)
            Nav.NavigateTo($"journal-entries/{entry.id}");
    }

    private async Task SaveAndPost()
    {
        var entry = await SaveEntry();
        if (entry != null)
        {
            try
            {
                await Accounting.PostJournalEntryAsync(entry.id, CompanyId!);
                Nav.NavigateTo($"journal-entries/{entry.id}");
            }
            catch (Exception ex) { error = ex.Message; }
        }
    }

    private async Task<JournalEntry?> SaveEntry()
    {
        error = null;
        saving = true;
        try
        {
            var entry = new JournalEntry
            {
                CompanyId = CompanyId!,
                EntryDate = entryDate,
                Description = description,
                Memo = memo,
                Lines = lines.Where(l => !string.IsNullOrEmpty(l.AccountId)).ToList()
            };

            var result = await Accounting.CreateJournalEntryAsync(entry);
            saving = false;
            return result;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            saving = false;
            return null;
        }
    }

    private async Task HandleNlKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(nlDescription) && !nlLoading)
            await GenerateFromNL();
    }

    private async Task GenerateFromNL()
    {
        if (string.IsNullOrWhiteSpace(nlDescription) || nlLoading) return;

        nlLoading = true;
        nlError = null;
        StateHasChanged();

        try
        {
            var accountList = string.Join("\n", accounts.Select(a => $"  {a.id}|{a.AccountNumber}|{a.Name}"));

            var systemPrompt = "You are an accounting assistant that converts plain-English transaction descriptions into double-entry journal entry lines.\n\n" +
                "Available accounts (format: id|number|name):\n" + accountList + "\n\n" +
                "You MUST respond with ONLY a valid JSON object:\n" +
                "{\n" +
                "    \"description\": \"Brief description for the entry\",\n" +
                "    \"date\": \"yyyy-MM-dd\",\n" +
                "    \"lines\": [\n" +
                "        { \"accountId\": \"account-id\", \"accountNumber\": \"number\", \"accountName\": \"name\", \"debit\": 0.00, \"credit\": 0.00 },\n" +
                "        { \"accountId\": \"account-id\", \"accountNumber\": \"number\", \"accountName\": \"name\", \"debit\": 0.00, \"credit\": 0.00 }\n" +
                "    ]\n" +
                "}\n\n" +
                "Rules:\n" +
                "- Total debits MUST equal total credits\n" +
                "- Use the exact account IDs from the list above\n" +
                "- Match accounts to the transaction semantically\n" +
                "- If no date is mentioned, use today's date";

            var result = await InferenceService.AnalyzeAsync(systemPrompt, nlDescription, 0.3f);
            var json = ExtractJsonFromResponse(result);

            if (json != null)
            {
                using var doc = System.Text.Json.JsonDocument.Parse(json);
                var root = doc.RootElement;

                if (root.TryGetProperty("description", out var desc))
                    description = desc.GetString() ?? nlDescription;

                if (root.TryGetProperty("date", out var dateEl) && DateTime.TryParse(dateEl.GetString(), out var parsedDate))
                    entryDate = parsedDate;

                if (root.TryGetProperty("lines", out var linesEl))
                {
                    lines.Clear();
                    foreach (var lineEl in linesEl.EnumerateArray())
                    {
                        var line = new JournalLine
                        {
                            AccountId = lineEl.TryGetProperty("accountId", out var aid) ? aid.GetString() ?? "" : "",
                            AccountNumber = lineEl.TryGetProperty("accountNumber", out var anum) ? anum.GetString() ?? "" : "",
                            AccountName = lineEl.TryGetProperty("accountName", out var aname) ? aname.GetString() ?? "" : "",
                            Debit = lineEl.TryGetProperty("debit", out var d) ? d.GetDecimal() : 0,
                            Credit = lineEl.TryGetProperty("credit", out var c) ? c.GetDecimal() : 0
                        };
                        lines.Add(line);
                    }
                }

                nlDescription = "";
            }
            else
            {
                nlError = "Couldn't parse the AI response. Try rephrasing your description.";
            }
        }
        catch
        {
            nlError = "Unable to generate entry. Please try again or enter manually.";
        }
        finally
        {
            nlLoading = false;
            StateHasChanged();
        }
    }

    private static string? ExtractJsonFromResponse(string response)
    {
        // Try code fence first
        var start = response.IndexOf("```json", StringComparison.OrdinalIgnoreCase);
        if (start >= 0)
        {
            start = response.IndexOf('\n', start) + 1;
            var end = response.IndexOf("```", start, StringComparison.Ordinal);
            if (end > start) return response[start..end].Trim();
        }

        start = response.IndexOf("```", StringComparison.Ordinal);
        if (start >= 0)
        {
            start = response.IndexOf('\n', start) + 1;
            var end = response.IndexOf("```", start, StringComparison.Ordinal);
            if (end > start) return response[start..end].Trim();
        }

        // Try raw JSON
        var jsonStart = response.IndexOf('{');
        if (jsonStart >= 0)
        {
            var jsonEnd = response.LastIndexOf('}');
            if (jsonEnd > jsonStart) return response[jsonStart..(jsonEnd + 1)];
        }

        return null;
    }
}

@using BookSmarts.Services

<div class="bs-pin-overlay">
    <div class="bs-pin-card" style="max-width: 520px;">
        <div class="text-center mb-4">
            <i class="fa-duotone fa-key bs-pin-icon"></i>
            <h4 class="mt-3">Reset Your PIN</h4>
            <p class="text-muted small">Enter your 12-word recovery phrase to reset your PIN.</p>
        </div>

        @if (step == 1)
        {
            <div class="mb-3">
                <label class="form-label">Recovery Phrase</label>
                <textarea class="form-control" rows="3" @bind="recoveryPhrase"
                          placeholder="Enter your 12-word recovery phrase, separated by spaces"></textarea>
            </div>
        }
        else if (step == 2)
        {
            <div class="mb-3">
                <label class="form-label">New 6-Digit PIN</label>
                <input type="password" class="form-control" maxlength="6" inputmode="numeric"
                       @bind="newPin" placeholder="Enter new PIN" />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm New PIN</label>
                <input type="password" class="form-control" maxlength="6" inputmode="numeric"
                       @bind="confirmPin" placeholder="Confirm new PIN" />
            </div>
        }

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger small">@error</div>
        }

        <div class="d-flex gap-2 justify-content-between">
            <button class="btn btn-outline-secondary" @onclick="GoBack">
                @(step == 1 ? "Back to PIN Entry" : "Back")
            </button>
            <button class="btn btn-primary" @onclick="Next" disabled="@processing">
                @if (processing)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                @(step == 1 ? "Next" : "Reset PIN")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnUnlocked { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string AccountId { get; set; } = "";
    [Inject] EncryptionSetupService SetupService { get; set; } = default!;

    private int step = 1;
    private string recoveryPhrase = "";
    private string newPin = "";
    private string confirmPin = "";
    private string? error;
    private bool processing;

    private async Task Next()
    {
        error = null;
        if (step == 1)
        {
            var words = recoveryPhrase.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (words.Length != 12)
            {
                error = "Recovery phrase must be exactly 12 words.";
                return;
            }
            step = 2;
        }
        else
        {
            if (newPin.Length != 6 || !newPin.All(char.IsDigit))
            {
                error = "PIN must be exactly 6 digits.";
                return;
            }
            if (newPin != confirmPin)
            {
                error = "PINs do not match.";
                return;
            }

            processing = true;
            StateHasChanged();

            try
            {
                var normalizedPhrase = string.Join(" ", recoveryPhrase.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries)).ToLowerInvariant();
                var success = await SetupService.ResetPinAsync(AccountId, normalizedPhrase, newPin);
                if (success)
                {
                    await OnUnlocked.InvokeAsync();
                }
                else
                {
                    error = "Invalid recovery phrase. Please check and try again.";
                    step = 1;
                }
            }
            catch (Exception ex)
            {
                error = $"Error: {ex.Message}";
            }

            processing = false;
        }
    }

    private async Task GoBack()
    {
        if (step == 2)
            step = 1;
        else
            await OnCancel.InvokeAsync();
    }
}

@if (Entry.Role == "user")
{
    <div class="d-flex justify-content-end mb-3">
        <div class="bs-chat-bubble bs-chat-user">
            <div class="small" style="white-space: pre-wrap;">@Entry.Content</div>
            <div class="text-end mt-1" style="font-size: 0.7rem; opacity: 0.6;">@Entry.Timestamp.ToLocalTime().ToString("h:mm tt")</div>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-start mb-3">
        <div class="bs-chat-bubble bs-chat-assistant">
            <div class="d-flex align-items-center mb-1">
                <i class="fa-duotone fa-wand-magic-sparkles me-1" style="color: var(--bs-accent, #6366f1); font-size: 0.8rem;"></i>
                <strong class="small">AI Advisor</strong>
            </div>
            <div class="small" style="white-space: pre-wrap;">@Entry.Content</div>
            <div class="text-end mt-1" style="font-size: 0.7rem; opacity: 0.6;">@Entry.Timestamp.ToLocalTime().ToString("h:mm tt")</div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public ChatEntry Entry { get; set; } = default!;
}

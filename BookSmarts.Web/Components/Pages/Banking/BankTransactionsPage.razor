    private async Task AiSuggestCategory()
    {
        if (selectedTxn == null || coaAccounts.Count == 0) return;

        aiCategorizing = true;
        aiCategoryReason = null;
        StateHasChanged();

        try
        {
            var accountList = string.Join("\n",
                coaAccounts.Where(a => a.IsActive)
                    .OrderBy(a => a.AccountNumber)
                    .Select(a => $"  {a.id}|{a.AccountNumber}|{a.Name}|{a.Category}"));

            var systemPrompt = "You are an accounting assistant that suggests chart of accounts mappings for bank transactions.\n\n" +
                "Available accounts (id|number|name|category):\n" + accountList + "\n\n" +
                "You MUST respond with ONLY a valid JSON object:\n" +
                "{ \"accountId\": \"the-account-id\", \"reason\": \"Brief explanation of why this account fits\" }\n\n" +
                "Rules:\n" +
                "- Choose the most appropriate account based on the transaction description, merchant, and amount\n" +
                "- Money coming IN (negative amount in Plaid = deposit) typically goes to Revenue accounts\n" +
                "- Money going OUT (positive amount in Plaid = withdrawal) typically goes to Expense accounts\n" +
                "- Be specific - choose the most fitting account, not a generic catch-all";

            var categories = selectedTxn.PlaidCategories.Count > 0
                ? string.Join(" > ", selectedTxn.PlaidCategories)
                : "none";

            var userPrompt = "Transaction:\n" +
                $"- Merchant: {selectedTxn.MerchantName ?? "unknown"}\n" +
                $"- Description: {selectedTxn.Name}\n" +
                $"- Amount: {selectedTxn.Amount:N2} (positive = money out, negative = money in)\n" +
                $"- Plaid categories: {categories}\n" +
                $"- Date: {selectedTxn.TransactionDate:yyyy-MM-dd}";

            var result = await InferenceService.AnalyzeAsync(systemPrompt, userPrompt, 0.3f);

            // Parse the suggestion
            var jsonStart = result.IndexOf('{');
            var jsonEnd = result.LastIndexOf('}');
            if (jsonStart >= 0 && jsonEnd > jsonStart)
            {
                var json = result[jsonStart..(jsonEnd + 1)];
                using var doc = System.Text.Json.JsonDocument.Parse(json);
                var root = doc.RootElement;

                if (root.TryGetProperty("accountId", out var aidEl))
                {
                    var suggestedId = aidEl.GetString() ?? "";
                    if (coaAccounts.Any(a => a.id == suggestedId))
                    {
                        categorizeAccountId = suggestedId;
                        aiCategoryReason = root.TryGetProperty("reason", out var reason)
                            ? reason.GetString() ?? ""
                            : "AI suggestion";
                    }
                }
            }
        }
        catch
        {
            aiCategoryReason = "Unable to suggest a category. Please select manually.";
        }
        finally
        {
            aiCategorizing = false;
            StateHasChanged();
        }
    }

    private async Task AutoCategorizeAll()
    {
        if (coaAccounts.Count == 0) return;

        autoCategorizingAll = true;
        autoCatSuggestions.Clear();
        autoCatSelectedIds.Clear();
        autoCatShowReview = false;
        autoCatProcessed = 0;
        autoCatSkipped = 0;
        autoCatPercent = 0;
        error = null;
        success = null;
        StateHasChanged();

        try
        {
            var uncategorized = transactions
                .Where(t => t.Status == BankTransactionStatus.Uncategorized)
                .ToList();
            autoCatTotal = uncategorized.Count;

            if (autoCatTotal == 0)
            {
                success = "No uncategorized transactions to process.";
                return;
            }

            // Phase 1: Collect rule-matched suggestions
            var ruleMatched = uncategorized
                .Where(t => t.MatchedRuleId != null && !string.IsNullOrEmpty(t.CategorizedAccountId))
                .ToList();

            foreach (var txn in ruleMatched)
            {
                var acct = coaAccounts.FirstOrDefault(a => a.id == txn.CategorizedAccountId);
                if (acct != null)
                {
                    autoCatSuggestions.Add(new AutoCatSuggestion(
                        txn.id, txn.MerchantName ?? "", txn.Name, txn.Amount,
                        acct.id, acct.AccountNumber, acct.Name, "Matched by rule", IsRuleMatch: true));
                }
                else
                {
                    autoCatSkipped++;
                }

                autoCatProcessed++;
                autoCatPercent = (double)autoCatProcessed / autoCatTotal * 100;
                StateHasChanged();
            }

            // Phase 2: AI-suggest remaining uncategorized — one call per unique merchant
            var needsAi = uncategorized
                .Where(t => t.MatchedRuleId == null || string.IsNullOrEmpty(t.CategorizedAccountId))
                .ToList();

            if (needsAi.Count > 0)
            {
                // Group by merchant key for consistent results
                var merchantGroups = needsAi
                    .GroupBy(t => (t.MerchantName ?? t.Name).Trim().ToLowerInvariant())
                    .ToList();

                var expenseAccounts = coaAccounts.Where(a => a.IsActive && a.Category == AccountCategory.Expense)
                    .OrderBy(a => a.AccountNumber).ToList();
                var revenueAccounts = coaAccounts.Where(a => a.IsActive && a.Category == AccountCategory.Revenue)
                    .OrderBy(a => a.AccountNumber).ToList();

                var expenseList = string.Join("\n", expenseAccounts.Select(a => $"  {a.AccountNumber} — {a.Name}"));
                var revenueList = string.Join("\n", revenueAccounts.Select(a => $"  {a.AccountNumber} — {a.Name}"));

                var systemPrompt = "You are an accounting assistant. Categorize a bank transaction to the best matching account.\n\n" +
                    "EXPENSE accounts:\n" + expenseList + "\n\n" +
                    "REVENUE accounts:\n" + revenueList + "\n\n" +
                    "Respond with ONLY a JSON object:\n" +
                    "{ \"account\": \"5000\", \"reason\": \"brief why\" }\n\n" +
                    "Rules:\n" +
                    "- \"account\" must be an account number from the lists above\n" +
                    "- The Plaid category and merchant name are the strongest hints. Match them to the closest account by meaning.\n" +
                    "- A negative amount can be a refund — use the Plaid category to decide the account, not the sign.\n" +
                    "- Only use Revenue accounts for actual income (e.g. customer payments, sales). Refunds from vendors are still expenses.\n" +
                    "- NEVER use Other Expense or a catch-all if a more specific account fits.";

                foreach (var group in merchantGroups)
                {
                    var rep = group.First();
                    var cats = rep.PlaidCategories.Count > 0
                        ? string.Join(" > ", rep.PlaidCategories) : "none";

                    var userPrompt = $"Merchant: {rep.MerchantName ?? "unknown"}\n" +
                        $"Description: {rep.Name}\n" +
                        $"Amount: {rep.Amount:N2} (positive = money out, negative = money in)\n" +
                        $"Plaid categories: {cats}";

                    try
                    {
                        var result = await InferenceService.AnalyzeAsync(systemPrompt, userPrompt, 0.3f);

                        var jsonStart = result.IndexOf('{');
                        var jsonEnd = result.LastIndexOf('}');
                        if (jsonStart >= 0 && jsonEnd > jsonStart)
                        {
                            var json = result[jsonStart..(jsonEnd + 1)];
                            using var doc = System.Text.Json.JsonDocument.Parse(json);
                            var root = doc.RootElement;

                            var acctNum = root.TryGetProperty("account", out var aidEl) ? aidEl.GetString() ?? "" : "";
                            var aiReason = root.TryGetProperty("reason", out var reasonEl) ? reasonEl.GetString() ?? "" : "";
                            var acct = coaAccounts.FirstOrDefault(a => a.AccountNumber == acctNum);

                            if (acct != null)
                            {
                                foreach (var txn in group)
                                {
                                    autoCatSuggestions.Add(new AutoCatSuggestion(
                                        txn.id, txn.MerchantName ?? "", txn.Name, txn.Amount,
                                        acct.id, acct.AccountNumber, acct.Name, aiReason, IsRuleMatch: false));
                                    autoCatProcessed++;
                                    autoCatPercent = (double)autoCatProcessed / autoCatTotal * 100;
                                }
                                StateHasChanged();
                                continue;
                            }
                        }
                    }
                    catch { }

                    // If we get here, this merchant wasn't matched
                    foreach (var txn in group)
                    {
                        autoCatSkipped++;
                        autoCatProcessed++;
                        autoCatPercent = (double)autoCatProcessed / autoCatTotal * 100;
                    }
                    StateHasChanged();
                }
            }

            // Show review panel with all suggestions pre-selected
            if (autoCatSuggestions.Count > 0)
            {
                autoCatSelectedIds = new(autoCatSuggestions.Select(s => s.TxnId));
                autoCatShowReview = true;
            }
            else
            {
                success = autoCatSkipped > 0
                    ? $"DAISI could not suggest accounts for {autoCatSkipped} transaction(s). Try categorizing manually."
                    : "No uncategorized transactions to process.";
            }
        }
        catch (Exception ex)
        {
            error = $"Auto-categorize failed: {ex.Message}";
        }
        finally
        {
            autoCategorizingAll = false;
            StateHasChanged();
        }
    }

    private async Task ApplyAutoCategorize()
    {
        if (autoCatSelectedIds.Count == 0) return;

        autoCategorizingApplying = true;
        autoCatSuccess = 0;
        autoCatRulesCreated = 0;
        var applySkipped = 0;
        autoCatProcessed = 0;
        autoCatTotal = autoCatSelectedIds.Count;
        autoCatPercent = 0;
        error = null;
        success = null;
        StateHasChanged();

        try
        {
            var selected = autoCatSuggestions.Where(s => autoCatSelectedIds.Contains(s.TxnId)).ToList();

            foreach (var s in selected)
            {
                try
                {
                    await Banking.CategorizeTransactionAsync(s.TxnId, CompanyId!,
                        s.AccountId, s.AccountNumber, s.AccountName, createRule: !s.IsRuleMatch);
                    autoCatSuccess++;
                    if (!s.IsRuleMatch && !string.IsNullOrEmpty(s.Merchant))
                        autoCatRulesCreated++;
                }
                catch
                {
                    applySkipped++;
                }

                autoCatProcessed++;
                autoCatPercent = (double)autoCatProcessed / autoCatTotal * 100;
                StateHasChanged();
            }

            var parts = new List<string>();
            if (autoCatSuccess > 0) parts.Add($"{autoCatSuccess} categorized");
            if (autoCatRulesCreated > 0) parts.Add($"{autoCatRulesCreated} rules created");
            if (applySkipped > 0) parts.Add($"{applySkipped} failed");
            success = $"Done: {string.Join(", ", parts)}.";

            autoCatShowReview = false;
            autoCatSuggestions.Clear();
            autoCatSelectedIds.Clear();
            selectedTxn = null;
            await LoadTransactions();
            if (RefreshBadges != null) await RefreshBadges();
        }
        catch (Exception ex)
        {
            error = $"Apply failed: {ex.Message}";
        }
        finally
        {
            autoCategorizingApplying = false;
            StateHasChanged();
        }
    }

    private void CancelAutoCategorize()
    {
        autoCatShowReview = false;
        autoCatSuggestions.Clear();
        autoCatSelectedIds.Clear();
    }
}

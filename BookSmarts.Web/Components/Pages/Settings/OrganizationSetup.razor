@page "/settings/organization"
@using BookSmarts.Services
@using BookSmarts.Core.Enums
@using BookSmarts.Core.Models

@if (CurrentUser != null && !PermissionService.CanManageOrganization(CurrentUser.Role))
{
    <div class="alert alert-warning">Only account Owners can manage organization settings.</div>
    return;
}

<h1 class="bs-page-title">Organization Setup</h1>
<p class="bs-page-subtitle">Manage your organization settings</p>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" />
}
else if (organization == null)
{
    <!-- Create new organization -->
    <div class="bs-card" style="max-width: 600px;">
        <h5>Create Organization</h5>
        <p class="text-muted small">Set up your organization to get started with BookSmarts.</p>

        <div class="mb-3">
            <label class="form-label">Organization Name</label>
            <input type="text" class="form-control" @bind="newOrgName" placeholder="e.g. Acme Corp" />
        </div>
        <div class="mb-3">
            <label class="form-label">Default Currency</label>
            <select class="form-select" @bind="newOrgCurrency">
                <option value="USD">USD — US Dollar</option>
                <option value="EUR">EUR — Euro</option>
                <option value="GBP">GBP — British Pound</option>
                <option value="CAD">CAD — Canadian Dollar</option>
            </select>
        </div>
        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" @bind="newOrgDivisions" id="divCheck">
            <label class="form-check-label" for="divCheck">Enable divisions (group companies into divisions)</label>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <button class="btn btn-primary" @onclick="CreateOrganization" disabled="@saving">
            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Create Organization
        </button>
    </div>
}
else
{
    <!-- Edit existing organization -->
    <div class="bs-card" style="max-width: 600px;">
        <div class="mb-3">
            <label class="form-label">Organization Name</label>
            <input type="text" class="form-control" @bind="organization.Name" />
        </div>
        <div class="mb-3">
            <label class="form-label">Default Currency</label>
            <select class="form-select" @bind="organization.DefaultCurrency">
                <option value="USD">USD — US Dollar</option>
                <option value="EUR">EUR — Euro</option>
                <option value="GBP">GBP — British Pound</option>
                <option value="CAD">CAD — Canadian Dollar</option>
            </select>
        </div>
        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" @bind="organization.DivisionsEnabled" id="divCheck">
            <label class="form-check-label" for="divCheck">Enable divisions</label>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }
        @if (!string.IsNullOrEmpty(success))
        {
            <div class="alert alert-success">@success</div>
        }

        <button class="btn btn-primary" @onclick="UpdateOrganization" disabled="@saving">
            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Save Changes
        </button>
    </div>

    <!-- Security Section -->
    <div class="bs-card mt-4" style="max-width: 600px;">
        <h5><i class="fa-duotone fa-shield-halved me-2"></i>Security</h5>
        <p class="text-muted small mb-3">Zero-knowledge encryption protects your financial data so that only you can read it.</p>

        @if (encryptionEnabled)
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="bs-badge bs-badge-posted">Encryption Enabled</span>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary btn-sm" @onclick="ShowChangePin" disabled="@saving">
                    <i class="fa-duotone fa-key me-1"></i> Change PIN
                </button>
                <button class="btn btn-outline-danger btn-sm" @onclick="ShowDisableEncryption" disabled="@saving">
                    <i class="fa-duotone fa-lock-open me-1"></i> Disable Encryption
                </button>
            </div>

            @if (showChangePinForm)
            {
                <div class="mt-3 p-3 border rounded">
                    <div class="mb-2">
                        <label class="form-label small">New 6-Digit PIN</label>
                        <input type="password" class="form-control form-control-sm" maxlength="6" inputmode="numeric" @bind="newPin" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Confirm New PIN</label>
                        <input type="password" class="form-control form-control-sm" maxlength="6" inputmode="numeric" @bind="confirmNewPin" />
                    </div>
                    @if (!string.IsNullOrEmpty(securityError))
                    {
                        <div class="alert alert-danger small py-1 px-2">@securityError</div>
                    }
                    @if (!string.IsNullOrEmpty(securitySuccess))
                    {
                        <div class="alert alert-success small py-1 px-2">@securitySuccess</div>
                    }
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="ChangePin" disabled="@saving">Save</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => showChangePinForm = false">Cancel</button>
                    </div>
                </div>
            }

            @if (showDisableConfirm)
            {
                <div class="mt-3 p-3 border border-danger rounded">
                    <p class="text-danger small mb-2">
                        <i class="fa-duotone fa-triangle-exclamation me-1"></i>
                        This will decrypt all your data and remove encryption protection. Are you sure?
                    </p>
                    @if (disabling)
                    {
                        <MudProgressLinear Value="@disablePercent" Color="MudBlazor.Color.Error" Rounded="true" Size="MudBlazor.Size.Small" class="mb-2" />
                        <p class="text-muted small">@disablePhase — @disableProcessed / @disableTotal</p>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger btn-sm" @onclick="DisableEncryption">Yes, Disable</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => showDisableConfirm = false">Cancel</button>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <p class="small mb-3">Encryption is not enabled. Enable it to protect all sensitive financial data with a 6-digit PIN.</p>
            <a class="btn btn-primary btn-sm" href="settings/encryption-setup">
                <i class="fa-duotone fa-shield-check me-1"></i> Enable Encryption
            </a>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "AccountId")] string AccountId { get; set; } = "";
    [CascadingParameter(Name = "CurrentUser")] BookSmartsUser? CurrentUser { get; set; }
    [Inject] OrganizationService OrgService { get; set; } = default!;
    [Inject] EncryptionSetupService EncryptionSetup { get; set; } = default!;
    [Inject] EncryptionMigrationService MigrationService { get; set; } = default!;
    [Inject] EncryptionContext EncryptionCtx { get; set; } = default!;

    private Organization? organization;
    private bool loading = true;
    private bool saving;
    private string? error;
    private string? success;
    private bool encryptionEnabled;

    private string newOrgName = "";
    private string newOrgCurrency = "USD";
    private bool newOrgDivisions;

    // Security form state
    private bool showChangePinForm;
    private bool showDisableConfirm;
    private string newPin = "";
    private string confirmNewPin = "";
    private string? securityError;
    private string? securitySuccess;
    private bool disabling;
    private double disablePercent;
    private string disablePhase = "";
    private int disableProcessed;
    private int disableTotal;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(AccountId)) return;
        loading = true;
        try
        {
            var orgs = await OrgService.GetOrganizationsAsync(AccountId);
            organization = orgs.FirstOrDefault();

            var encConfig = await EncryptionSetup.GetConfigAsync(AccountId);
            encryptionEnabled = encConfig is { IsEnabled: true };
        }
        catch { /* Cosmos not configured */ }
        loading = false;
    }

    private async Task CreateOrganization()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(newOrgName))
        {
            error = "Organization name is required.";
            return;
        }

        saving = true;
        try
        {
            organization = await OrgService.CreateOrganizationAsync(new Organization
            {
                AccountId = AccountId,
                Name = newOrgName.Trim(),
                DefaultCurrency = newOrgCurrency,
                DivisionsEnabled = newOrgDivisions
            });
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        saving = false;
    }

    private async Task UpdateOrganization()
    {
        error = null;
        success = null;
        saving = true;
        try
        {
            organization = await OrgService.UpdateOrganizationAsync(organization!);
            success = "Organization updated.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        saving = false;
    }

    private void ShowChangePin()
    {
        showChangePinForm = true;
        showDisableConfirm = false;
        securityError = null;
        securitySuccess = null;
        newPin = "";
        confirmNewPin = "";
    }

    private async Task ChangePin()
    {
        securityError = null;
        securitySuccess = null;

        if (newPin.Length != 6 || !newPin.All(char.IsDigit))
        {
            securityError = "PIN must be exactly 6 digits.";
            return;
        }
        if (newPin != confirmNewPin)
        {
            securityError = "PINs do not match.";
            return;
        }

        saving = true;
        try
        {
            await EncryptionSetup.ChangePinAsync(AccountId, newPin);
            securitySuccess = "PIN changed successfully.";
            newPin = "";
            confirmNewPin = "";
        }
        catch (Exception ex)
        {
            securityError = ex.Message;
        }
        saving = false;
    }

    private void ShowDisableEncryption()
    {
        showDisableConfirm = true;
        showChangePinForm = false;
    }

    private async Task DisableEncryption()
    {
        disabling = true;
        StateHasChanged();

        try
        {
            var progress = new Progress<MigrationProgress>(p =>
            {
                disableProcessed = p.Processed;
                disableTotal = p.Total;
                disablePercent = p.Percentage;
                disablePhase = p.CurrentPhase;
                InvokeAsync(StateHasChanged);
            });

            await MigrationService.DecryptAllDataAsync(AccountId, progress);
            await EncryptionSetup.DisableEncryptionAsync(AccountId);
            encryptionEnabled = false;
            showDisableConfirm = false;
        }
        catch (Exception ex)
        {
            securityError = ex.Message;
        }

        disabling = false;
    }
}
